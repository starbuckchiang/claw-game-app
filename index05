<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>甜心夾娃娃機 Plus 兌換版</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Microsoft JhengHei", "PingFang TC", sans-serif;
      background: linear-gradient(180deg, #ffe6f2 0%, #fff7fb 100%);
      color: #5a3d4d;
    }
    .wrap {
      max-width: 1160px;
      margin: 0 auto;
      padding: 20px 14px 40px;
    }
    .card, .machine, .showcase, .leaderboard, .adbox {
      background: #fff;
      border: 4px solid #f8bfd8;
      border-radius: 24px;
      box-shadow: 0 14px 30px rgba(225, 131, 175, 0.18);
    }
    .card { padding: 20px; }
    h1, h2, h3 {
      margin: 0 0 10px;
      color: #d45c92;
      text-align: center;
    }
    p {
      color: #8b6678;
      line-height: 1.7;
      text-align: center;
    }
    .icon-links, .controls, .board-actions {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 14px;
    }
    button, .icon-link {
      border: none;
      background: #ff8fbc;
      color: white;
      font-size: 16px;
      padding: 12px 18px;
      border-radius: 999px;
      cursor: pointer;
      min-width: 96px;
      box-shadow: 0 6px 14px rgba(236, 113, 164, 0.2);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .start-btn { background: linear-gradient(90deg, #ff93c2, #ffb36c); }
    .coin-btn { background: #ffb347; }
    .secondary-btn { background: linear-gradient(90deg, #ffb7cf, #ffc9a6); }
    .gift-btn { background: linear-gradient(90deg, #8ec5ff, #7ea7ff); }

    .hud {
      margin-top: 18px;
      background: #fff;
      border: 3px solid #f8bfd8;
      border-radius: 18px;
      padding: 12px;
      display: flex;
      gap: 12px;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    #message {
      width: 100%;
      text-align: center;
      font-weight: bold;
      color: #d45c92;
    }

    .layout {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 16px;
      margin-top: 18px;
      align-items: start;
    }

    .machine, .showcase, .leaderboard, .adbox {
      padding: 16px;
    }

    .top-bar {
      width: 100%;
      height: 18px;
      background: repeating-linear-gradient(45deg,#ffd3e6,#ffd3e6 12px,#ffc1da 12px,#ffc1da 24px);
      border-radius: 12px;
      margin-bottom: 10px;
    }

    .claw-track { position: relative; height: 80px; }
    .claw-arm {
      position: absolute;
      top: 0;
      left: 180px;
      width: 80px;
      transition: left 0.2s ease;
      z-index: 10;
    }
    .claw-head {
      width: 42px;
      height: 14px;
      margin: 0 auto;
      background: #ff89b5;
      border-radius: 999px;
    }
    .rope {
      width: 4px;
      height: 28px;
      background: #9c7b8b;
      margin: 0 auto;
      transition: height 0.3s ease;
    }
    .claw {
      position: relative;
      width: 40px;
      height: 30px;
      margin: 0 auto;
    }
    .finger {
      position: absolute;
      top: 0;
      width: 12px;
      height: 24px;
      border: 4px solid #8e6f7f;
      border-top: none;
      border-radius: 0 0 12px 12px;
      background: transparent;
    }
    .finger.left { left: 2px; transform: rotate(14deg); }
    .finger.right { right: 2px; transform: rotate(-14deg); }
    .claw.closed .finger.left { transform: rotate(5deg); }
    .claw.closed .finger.right { transform: rotate(-5deg); }

    .play-area {
      position: relative;
      margin-top: 8px;
      height: 340px;
      border: 4px solid #ffd0e3;
      border-radius: 18px;
background: linear-gradient(180deg, #fffafc 0%, #ffeef5 100%);
      overflow: hidden;
    }
    .play-area::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 38px;
      background: #ffd7e8;
    }
    .prize {
      position: absolute;
      width: 54px;
      height: 54px;
      border-radius: 16px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 34px;
      box-shadow: 0 6px 14px rgba(225, 131, 175, 0.12);
      user-select: none;
      transition: left 0.4s ease, top 0.4s ease, transform 0.3s ease;
      z-index: 2;
    }

    .showcase-grid {
      min-height: 180px;
      border: 2px dashed #f6c2d9;
      border-radius: 16px;
      background: #fffafc;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      padding: 12px;
      justify-items: center;
      align-items: center;
    }
    .toy {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      box-shadow: 0 6px 14px rgba(225,131,175,.12);
    }

    .adbox {
      margin-top: 16px;
      text-align: center;
      background: linear-gradient(180deg, #fffafc 0%, #fff0f6 100%);
    }
    .ad-slot {
      border: 2px dashed #f6c2d9;
      border-radius: 16px;
      padding: 16px;
      background: #fff;
      color: #8b6678;
      line-height: 1.7;
      margin-top: 10px;
    }

    .gift-progress {
      margin-top: 12px;
      padding: 12px;
      border-radius: 14px;
      background: #fff7fb;
      color: #8b6678;
      text-align: center;
      font-size: 14px;
      line-height: 1.7;
      border: 2px solid #f6d3e2;
    }

    ol {
      margin: 0;
      padding-left: 22px;
      line-height: 1.9;
      color: #7b5b6b;
      min-height: 140px;
    }

    .hint {
      font-size: 13px;
      color: #8b6678;
      text-align: center;
      margin-top: 10px;
      line-height: 1.6;
    }

    @media (max-width: 900px) {
      .layout { grid-template-columns: 1fr; }
      .hud { flex-direction: column; align-items: center; }
      .play-area { height: 280px; }
      .prize { width: 46px; height: 46px; font-size: 30px; }
      .claw-arm { left: 130px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1>甜心夾娃娃機 Plus 兌換版</h1>
      <p>
        新手送 100 金幣、每日 +50、看廣告 +100 金幣 +1 次機會。<br>
        夾到虛擬圖可累積分數、點數、兌換券，還能去 gift.html 直接換實體商品。
      </p>

      <div class="icon-links">
        <a class="icon-link secondary-btn" href="./index.html">🏠 原版首頁</a>
        <a class="icon-link secondary-btn" href="./index04.html">🎀 Index04</a>
        <a class="icon-link gift-btn" href="./gift.html">🎁 去兌換實體商品</a>
      </div>

      <div class="hud">
        <div>🪙 金幣：<span id="coins">100</span></div>
        <div>⭐ 分數：<span id="score">0</span></div>
        <div>💎 點數：<span id="points">0</span></div>
        <div>🎟 兌換券：<span id="tickets">0</span></div>
        <div>🎯 可玩次數：<span id="tries">10</span></div>
        <div>🎫 免費次數：<span id="bonusPlays">0</span></div>
        <div>📦 成功夾取：<span id="catchCount">0</span></div>
        <div id="message">先左右移動，再按下爪試試手氣吧！</div>
      </div>

      <div class="layout">
        <div>
          <div class="machine">
            <h3>🎀 娃娃機</h3>
            <div class="top-bar"></div>

            <div class="claw-track">
              <div id="clawArm" class="claw-arm">
                <div class="claw-head"></div>
                <div id="rope" class="rope"></div>
                <div id="claw" class="claw">
                  <div class="finger left"></div>
                  <div class="finger right"></div>
                </div>
              </div>
            </div>

            <div id="playArea" class="play-area"></div>

            <div class="controls">
<button id="leftBtn">⬅ 左移</button>
              <button id="dropBtn" class="start-btn">下爪（10 金幣 / 免費次數）</button>
              <button id="rightBtn">右移 ➡</button>
            </div>

            <div class="hint">
              每成功夾到 5 次送 1 張兌換券；每成功 10 次再送 1 個 Bonus 禮物。
            </div>
          </div>

          <div class="adbox">
            <h3>📺 廣告獎勵區</h3>
            <div class="ad-slot">
              這裡先放預留廣告版位。<br>
              點按示意按鈕後，先模擬「看完獎勵廣告」並發送獎勵。
            </div>
            <div class="board-actions">
              <button id="watchAdBtn" class="coin-btn">看廣告：+100 金幣 +1 次</button>
            </div>
          </div>
        </div>

        <div class="showcase">
          <h3>🎉 我的展示櫃</h3>
          <div id="showcase" class="showcase-grid"></div>

          <div class="gift-progress">
            <div>夾 10 送 1：目前進度 <strong><span id="giftProgress">0</span>/10</strong></div>
            <div>每成功 5 次送 1 張兌換券，可拿去 gift.html 使用。</div>
          </div>

          <div class="board-actions">
            <button id="dailyBtn" class="coin-btn">每日登入 +50 金幣</button>
          </div>
        </div>

        <div class="leaderboard">
          <h3>🏆 本機排行榜</h3>
          <ol id="leaderboard"></ol>
          <div class="board-actions">
            <button id="saveBtn">儲存成績</button>
            <button id="resetBtn" class="secondary-btn">清空排行榜</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const prizePool = [
      { name: "小熊", emoji: "🧸", score: 20, points: 20, rarity: "common" },
      { name: "兔兔", emoji: "🐰", score: 20, points: 20, rarity: "common" },
      { name: "小貓", emoji: "🐱", score: 80, points: 80, rarity: "rare" },
      { name: "企鵝", emoji: "🐧", score: 80, points: 80, rarity: "rare" },
      { name: "皇冠熊", emoji: "👑", score: 200, points: 200, rarity: "legendary" }
    ];

    const bonusGiftPool = [
      { name: "Bonus 愛心禮物", emoji: "💝", score: 120, points: 120, rarity: "bonus" },
      { name: "Bonus 星星禮物", emoji: "🌟", score: 120, points: 120, rarity: "bonus" },
      { name: "Bonus 花花禮物", emoji: "🌸", score: 120, points: 120, rarity: "bonus" }
    ];

    let coins = Number(localStorage.getItem("clawCoins05")) || 100;
    let score = Number(localStorage.getItem("clawScore05")) || 0;
    let points = Number(localStorage.getItem("clawPoints05")) || 0;
    let tickets = Number(localStorage.getItem("clawTickets05")) || 0;
    let bonusPlays = Number(localStorage.getItem("clawBonusPlays05")) || 0;
    let catchCount = Number(localStorage.getItem("clawCatchCount05")) || 0;
    let clawX = 180;
    let isDropping = false;
    let prizes = [];

    const coinsEl = document.getElementById("coins");
    const scoreEl = document.getElementById("score");
    const pointsEl = document.getElementById("points");
    const ticketsEl = document.getElementById("tickets");
    const triesEl = document.getElementById("tries");
    const bonusPlaysEl = document.getElementById("bonusPlays");
    const catchCountEl = document.getElementById("catchCount");
    const giftProgressEl = document.getElementById("giftProgress");
    const messageEl = document.getElementById("message");
    const leaderboardEl = document.getElementById("leaderboard");
    const showcaseEl = document.getElementById("showcase");
    const playArea = document.getElementById("playArea");
    const clawArm = document.getElementById("clawArm");
    const clawEl = document.getElementById("claw");
    const ropeEl = document.getElementById("rope");

    function saveState() {
      localStorage.setItem("clawCoins05", coins);
      localStorage.setItem("clawScore05", score);
      localStorage.setItem("clawPoints05", points);
      localStorage.setItem("clawTickets05", tickets);
      localStorage.setItem("clawBonusPlays05", bonusPlays);
      localStorage.setItem("clawCatchCount05", catchCount);
    }

    function setMessage(text) {
      messageEl.textContent = text;
    }

    function updateUI() {
coinsEl.textContent = coins;
      scoreEl.textContent = score;
      pointsEl.textContent = points;
      ticketsEl.textContent = tickets;
      triesEl.textContent = Math.floor(coins / 10) + bonusPlays;
      bonusPlaysEl.textContent = bonusPlays;
      catchCountEl.textContent = catchCount;
      giftProgressEl.textContent = catchCount % 10;
    }

    function getBoard() {
      return JSON.parse(localStorage.getItem("clawLeaderboard05") || "[]");
    }

    function renderBoard() {
      const board = getBoard();
      leaderboardEl.innerHTML = board.length
        ? board.map((x, i) => `<li>${i + 1}. ${x.name}｜${x.score} 分｜${x.date}</li>`).join("")
        : "<li>還沒有紀錄，快來成為第一名！</li>";
    }

    function getShowcase() {
      return JSON.parse(localStorage.getItem("clawShowcase05") || "[]");
    }

    function renderShowcase() {
      const list = getShowcase();
      if (!list.length) {
        showcaseEl.innerHTML = '<div style="grid-column:1/-1;color:#b8899e;text-align:center;">還沒抽到虛擬圖，快試試手氣！</div>';
        return;
      }
      showcaseEl.innerHTML = list.slice(-8).reverse().map(item =>
        `<div class="toy" title="${item.name}｜${item.points}點">${item.emoji}</div>`
      ).join("");
    }

    function addToShowcase(prize) {
      const list = getShowcase();
      list.push(prize);
      localStorage.setItem("clawShowcase05", JSON.stringify(list));
      renderShowcase();
    }

    function saveScore() {
      const name = prompt("輸入暱稱：") || "神秘玩家";
      const board = getBoard();
      board.push({
        name: name.trim() || "神秘玩家",
        score,
        date: new Date().toLocaleDateString("zh-TW")
      });
      board.sort((a, b) => b.score - a.score);
      localStorage.setItem("clawLeaderboard05", JSON.stringify(board.slice(0, 10)));
      renderBoard();
      setMessage("成績已儲存到本機排行榜！");
    }

    function dailyBonus() {
      const today = new Date().toDateString();
      const last = localStorage.getItem("clawLastBonusDate05");
      if (last === today) {
        alert("今天已經領過每日 50 金幣了！");
        setMessage("今天的每日登入獎勵已經領過囉～");
        return;
      }
      coins += 50;
      localStorage.setItem("clawLastBonusDate05", today);
      saveState();
      updateUI();
      setMessage("每日登入成功，+50 金幣！");
    }

    function rewardAd() {
      alert("廣告播放完成（示意版）！");
      coins += 100;
      bonusPlays += 1;
      saveState();
      updateUI();
      setMessage("看廣告成功：+100 金幣、+1 次免費機會！");
    }

    function resetBoard() {
      if (!confirm("確定要清空本機排行榜嗎？")) return;
      localStorage.removeItem("clawLeaderboard05");
      renderBoard();
      setMessage("排行榜已清空。");
    }

    function createPrizes() {
      playArea.innerHTML = "";
      prizes = [];
      const cols = [40, 120, 200, 280, 360];
      const rows = [170, 230, 280];

      for (let i = 0; i < 7; i++) {
        const prize = prizePool[Math.floor(Math.random() * prizePool.length)];
        const el = document.createElement("div");
        el.className = "prize";
        el.textContent = prize.emoji;

        const x = cols[Math.floor(Math.random() * cols.length)] + Math.floor(Math.random() * 12);
        const y = rows[Math.floor(Math.random() * rows.length)] + Math.floor(Math.random() * 10);

        el.style.left = x + "px";
        el.style.top = y + "px";

        playArea.appendChild(el);
        prizes.push({ ...prize, x, y, el });
      }
    }

    function moveClaw(delta) {
      if (isDropping) return;
      clawX += delta;
      const maxX = Math.max(20, playArea.clientWidth - 80);
      clawX = Math.max(20, Math.min(maxX, clawX));
      clawArm.style.left = clawX + "px";
    }

    function spendForPlay() {
      if (bonusPlays > 0) {
        bonusPlays -= 1;
        saveState();
        updateUI();
        return true;
      }
      if (coins < 10) {
        alert("金幣不足！可以先看廣告或領每日獎勵。");
        setMessage("金幣不足，先去領獎勵吧！");
        return false;
      }
      coins -= 10;
      saveState();
      updateUI();
      return true;
}

    function getNearestPrize() {
      let best = null;
      let bestDistance = Infinity;
      const clawCenter = clawX + 20;
      prizes.forEach(prize => {
        const prizeCenter = prize.x + 27;
        const dx = Math.abs(prizeCenter - clawCenter);
        if (dx < bestDistance) {
          bestDistance = dx;
          best = prize;
        }
      });
      return { prize: best, distance: bestDistance };
    }

    function rewardBonusGiftIfNeeded() {
      if (catchCount > 0 && catchCount % 10 === 0) {
        const bonusGift = bonusGiftPool[Math.floor(Math.random() * bonusGiftPool.length)];
        addToShowcase(bonusGift);
        score += bonusGift.score;
        points += bonusGift.points;
        saveState();
        updateUI();
        setMessage(`恭喜達成夾 10 送 1！獲得 ${bonusGift.name}，再加 ${bonusGift.points} 點`);
      }
    }

    function rewardTicketIfNeeded() {
      if (catchCount > 0 && catchCount % 5 === 0) {
        tickets += 1;
        saveState();
        updateUI();
        setMessage(`恭喜累積成功 ${catchCount} 次！獲得 1 張兌換券`);
      }
    }

    function dropClaw() {
      if (isDropping) return;
      if (!spendForPlay()) return;

      isDropping = true;
      setMessage("下爪中…");
      ropeEl.style.height = "180px";
      clawEl.classList.add("closed");

      setTimeout(() => {
        const { prize, distance } = getNearestPrize();
        let caught = false;

        if (prize && distance < 38) {
          const baseChance = distance < 18 ? 0.88 : 0.58;
          caught = Math.random() < baseChance;
        }

        if (caught && prize) {
          prize.el.style.top = "120px";
          prize.el.style.left = clawX + "px";
          prize.el.style.transform = "scale(1.1)";

          setTimeout(() => {
            prize.el.remove();
            prizes = prizes.filter(p => p !== prize);

            catchCount += 1;
            score += prize.score;
            points += prize.points;
            addToShowcase(prize);

            rewardTicketIfNeeded();
            rewardBonusGiftIfNeeded();

            saveState();
            updateUI();

            if (prize.rarity === "legendary") {
              setMessage(`傳說級 ${prize.name} 到手！+${prize.score} 分 / +${prize.points} 點`);
            } else if (prize.rarity === "rare") {
              setMessage(`夾到稀有 ${prize.name}！+${prize.score} 分 / +${prize.points} 點`);
            } else {
              setMessage(`夾到 ${prize.name}！+${prize.score} 分 / +${prize.points} 點`);
            }

            if (!prizes.length) {
              setTimeout(() => {
                createPrizes();
                setMessage("新的一批娃娃補上囉！");
              }, 600);
            }
          }, 450);
        } else {
          setMessage("差一點點！再調整位置一次試試看～");
        }

        setTimeout(() => {
          ropeEl.style.height = "28px";
          clawEl.classList.remove("closed");
          isDropping = false;
        }, 300);
      }, 700);
    }

    document.getElementById("leftBtn").addEventListener("click", () => moveClaw(-30));
    document.getElementById("rightBtn").addEventListener("click", () => moveClaw(30));
    document.getElementById("dropBtn").addEventListener("click", dropClaw);
    document.getElementById("dailyBtn").addEventListener("click", dailyBonus);
    document.getElementById("saveBtn").addEventListener("click", saveScore);
    document.getElementById("resetBtn").addEventListener("click", resetBoard);
    document.getElementById("watchAdBtn").addEventListener("click", rewardAd);

    window.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") moveClaw(-30);
      if (e.key === "ArrowRight") moveClaw(30);
      if (e.key === " " || e.key === "Enter") {
        e.preventDefault();
        dropClaw();
      }
    });

    updateUI();
    renderBoard();
    renderShowcase();
    createPrizes();
  </script>
</body>
</html>
